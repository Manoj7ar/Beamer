# ── Google Cloud ──────────────────────────────────────────────────────────────
# Your GCP project ID (string, e.g. "my-project-123")
GOOGLE_CLOUD_PROJECT=your-project-id

# Region — us-central1 has Imagen + Gemini + TTS all available
GOOGLE_CLOUD_LOCATION=us-central1

# ── GCS Bucket ────────────────────────────────────────────────────────────────
# Bucket where generated images and audio are stored (must exist, must be public)
GCS_BUCKET_NAME=beamer-media-2025

# ── Gemini via Vertex AI ──────────────────────────────────────────────────────
# Set this so ADK routes Gemini calls through Vertex AI (same creds as Imagen/TTS)
GOOGLE_GENAI_USE_VERTEXAI=1

# ── Local auth (development only) ─────────────────────────────────────────────
# Run: gcloud auth application-default login
# Then set your project: gcloud config set project YOUR_PROJECT_ID
# No key file needed — ADC handles authentication automatically.
